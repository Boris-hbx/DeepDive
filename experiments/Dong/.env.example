# DeepDive (Dong) 本地配置
#
# 用法：
#   cp .env.example .env
#   # 编辑 .env 填上真值（.env 已被 .gitignore 排除，不会进仓库）
#
# 加载时机：每次跑 `python -m deep_dive ...`，cli 启动时读这个文件注入环境变量。
# 优先级：shell 已 export 的优先，.env 不会覆盖（方便临时改 key 调试）。

# ============================================================
# LLM 后端选择
# ============================================================
# anthropic：直接走 Anthropic（或兼容代理；Claude Sonnet 4.6 / Opus 4.7）
# openai：   走 OpenAI 兼容协议（Gemini / DeepSeek / Kimi / OpenRouter / 自架等）
LLM_BACKEND=anthropic

# ============================================================
# Anthropic backend（LLM_BACKEND=anthropic 时使用）
# ============================================================
# 直访 Anthropic：填 key，BASE_URL 留空
# 走兼容代理：填代理给的 key + 代理 BASE_URL
# 注意：Claude Code 风格代理（注入工具集、共享 Code 池）与本流水线不兼容，
#       需要的是"按 token 转发"型 API 中转。
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# ============================================================
# OpenAI 兼容 backend（LLM_BACKEND=openai 时使用）
# ============================================================
# 不同提供商对应不同 BASE_URL + MODEL，挑一个填：
#
# Gemini AI Studio（免费额度大；需 VPN）:
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_MODEL=gemini-2.5-flash      # 或 gemini-2.5-pro
#   key 来自 https://aistudio.google.com/app/apikey
#
# DeepSeek（不需 VPN）:
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
#
# Kimi / Moonshot（不需 VPN）:
#   OPENAI_BASE_URL=https://api.moonshot.cn/v1
#   OPENAI_MODEL=kimi-latest
#
# OpenRouter（多模型聚合；需 VPN）:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=anthropic/claude-sonnet-4.5    # 或其他他们家命名
#
# 自架 LiteLLM:
#   OPENAI_BASE_URL=http://your-vps:4000/v1
#   OPENAI_MODEL=...
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# 主动节流：每次 API 调用间至少间隔 N 秒（防触发 free tier 限速）
# - Gemini AI Studio Free Tier: 5 RPM → 13
# - 付费档 / DeepSeek / Kimi 一般不限速 → 0（默认）
OPENAI_MIN_REQUEST_INTERVAL=

# 推理深度（仅支持 reasoning 的模型有效）：none / minimal / low / medium / high
# - Gemini 2.5 Flash/Pro 默认会 thinking，吃 max_tokens 预算 → 设 none 关掉
# - DeepSeek-R1 / OpenAI o1/o3 等推理模型：按需调
# - 其他不支持的模型：留空（默认）
OPENAI_REASONING_EFFORT=
