# DeepDive (Dong) 本地配置
#
# 用法：
#   cp .env.example .env
#   # 编辑 .env 填上真值（.env 已被 .gitignore 排除，不会进仓库）
#
# 加载时机：每次跑 `python -m deep_dive ...`，cli 启动时读这个文件注入环境变量。
# 优先级：shell 已 export 的优先，.env 不会覆盖（方便临时改 key 调试）。

# Anthropic API 凭证。
# - 直访 Anthropic：填 key 即可，BASE_URL 留空或注释掉
# - 走第三方代理：填代理给的 key，BASE_URL 指向代理（带 /v1）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
