---
const { title } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — DeepDive (Dong)</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #fafaf7;
        --bg-soft: #f4f2eb;
        --text: #2a2a2a;
        --text-soft: #6b6b66;
        --text-faint: #9a9a93;
        --accent: #4a6741;
        --accent-soft: #6b8466;
        --rule: #e8e5dc;
      }

      * { box-sizing: border-box; }

      html, body { background: var(--bg); }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB',
          'Inter', 'Segoe UI', 'Microsoft YaHei', sans-serif;
        max-width: 680px;
        margin: 3rem auto 5rem;
        padding: 0 1.25rem;
        line-height: 1.75;
        font-size: 17px;
        color: var(--text);
        font-feature-settings: 'kern', 'liga';
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3 {
        line-height: 1.35;
        font-weight: 600;
        letter-spacing: -.005em;
      }
      h1 {
        font-size: 1.7rem;
        margin: 0 0 1.5rem;
        font-weight: 650;
      }
      h2 {
        font-size: 1.2rem;
        margin: 2.5rem 0 .8rem;
        color: var(--text);
      }
      h3 {
        font-size: 1.05rem;
        margin: 1.8rem 0 .5rem;
        color: var(--text);
      }

      p { margin: .8rem 0; }

      a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
        transition: border-color .15s ease;
      }
      a:hover { border-bottom-color: var(--accent); }

      ul, ol { padding-left: 1.4rem; }
      ul li, ol li { margin: .35rem 0; }

      ul.brief-list {
        list-style: none;
        padding: 0;
        margin: 1.5rem 0;
      }
      ul.brief-list li {
        padding: .9rem 0;
        border-bottom: 1px solid var(--rule);
      }
      ul.brief-list li:last-child { border-bottom: none; }
      ul.brief-list a {
        border-bottom: none;
        color: var(--text);
      }
      ul.brief-list a:hover { color: var(--accent); }

      blockquote {
        color: var(--text-soft);
        border-left: 2px solid var(--rule);
        padding: .1rem 0 .1rem 1rem;
        margin: 1.2rem 0;
        font-size: .98rem;
      }
      blockquote p { margin: .3rem 0; }

      code {
        font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, monospace;
        font-size: .9em;
        background: var(--bg-soft);
        padding: .1em .35em;
        border-radius: 3px;
      }
      pre {
        background: var(--bg-soft);
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        line-height: 1.55;
      }
      pre code { background: none; padding: 0; }

      hr {
        border: none;
        border-top: 1px solid var(--rule);
        margin: 2.5rem 0;
      }

      .meta { color: var(--text-faint); font-size: .92rem; }

      nav {
        margin-bottom: 3rem;
        font-size: .92rem;
      }
      nav a {
        color: var(--text-faint);
        border-bottom: none;
      }
      nav a:hover { color: var(--accent); }

      strong { font-weight: 600; }
    </style>
  </head>
  <body>
    <nav><a href={import.meta.env.BASE_URL}>← 首页</a></nav>
    <slot />
  </body>
</html>
