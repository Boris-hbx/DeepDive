---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const briefModules = import.meta.glob('../../../../briefs/*.md', { eager: true });
  const obsModules = import.meta.glob('../../../../observations/*.md', { eager: true });
  const obsSlugs = new Set(
    Object.keys(obsModules).map((p) => p.split('/').pop()!.replace('.md', '')),
  );
  return Object.entries(briefModules).map(([path, mod]: [string, any]) => {
    const slug = path.split('/').pop()!.replace('.md', '');
    return {
      params: { slug },
      props: {
        Content: mod.Content ?? mod.default,
        frontmatter: mod.frontmatter ?? {},
        hasObservation: obsSlugs.has(slug),
      },
    };
  });
}

const { Content, hasObservation } = Astro.props;
const { slug } = Astro.params;
---
<Base title={slug}>
  <Content />
  {hasObservation && (
    <p class="observation-link">
      → <a href={`${import.meta.env.BASE_URL}observations/${slug}/`}>今日观察（二次提炼）</a>
    </p>
  )}
</Base>

<style>
  .observation-link {
    margin-top: 3rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--rule);
    font-size: .95rem;
    color: var(--text-soft);
  }
</style>
