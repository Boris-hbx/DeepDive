---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const obsModules = import.meta.glob('../../../../observations/*.md', { eager: true });
  const briefModules = import.meta.glob('../../../../briefs/*.md', { eager: true });
  const briefSlugs = new Set(
    Object.keys(briefModules).map((p) => p.split('/').pop()!.replace('.md', '')),
  );
  return Object.entries(obsModules).map(([path, mod]: [string, any]) => {
    const slug = path.split('/').pop()!.replace('.md', '');
    return {
      params: { slug },
      props: {
        Content: mod.Content ?? mod.default,
        frontmatter: mod.frontmatter ?? {},
        hasBrief: briefSlugs.has(slug),
      },
    };
  });
}

const { Content, hasBrief } = Astro.props;
const { slug } = Astro.params;
---
<Base title={`${slug} · 观察`}>
  {hasBrief && (
    <p class="brief-link-top">
      ← <a href={`${import.meta.env.BASE_URL}briefs/${slug}/`}>回到当日 brief</a>
    </p>
  )}
  <Content />
</Base>

<style>
  .brief-link-top {
    margin: 0 0 2rem;
    font-size: .95rem;
    color: var(--text-soft);
  }
</style>
