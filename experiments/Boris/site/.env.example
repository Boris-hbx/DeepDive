# Anthropic API key — required for /api/analyze-video
# Local dev: copy this file to .env.local and fill the real key (.env.local is gitignored)
# Fly: set via `fly secrets set ANTHROPIC_API_KEY=sk-ant-...`
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Default model for analyze pipeline. Override per-request only if needed.
ANTHROPIC_MODEL=claude-sonnet-4-6
